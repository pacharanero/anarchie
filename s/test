#
# Run the full test suite. Forwards arguments to `cargo test`, so you can run a
# single test (`s/test <name>`) or add flags (`s/test --release`).

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

exec cargo test "$@"

# Serve the anarchie documentation site locally with live reload.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# Use the local docs venv if it exists, otherwise fall back to a global zensical.
if [[ -f .venv-docs/bin/activate ]]; then
  # shellcheck disable=SC1091
  source .venv-docs/bin/activate
fi

exec zensical serve --open

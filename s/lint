#
# Run the formatting and lint checks CI enforces: `cargo fmt --check` and
# `cargo clippy --all-targets -- -D warnings`. Run this before every commit
# (the optional pre-commit hook runs it). The full test suite is `s/test`.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

cargo fmt --all --check
exec cargo clippy --all-targets -- -D warnings
